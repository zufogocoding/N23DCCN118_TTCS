// ==========================================
// CẤU HÌNH KẾT NỐI (Yêu cầu Prisma 5.1+ để dùng extensions)
// ==========================================
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"] // Bật tính năng nhận diện extension
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector] // Kích hoạt pgvector
}

// ==========================================
// 1. CÁC THỰC THỂ CHÍNH (BASE MODELS)
// ==========================================

model User {
  id         Int       @id @default(autoincrement())
  username   String    @db.VarChar(100)
  email      String    @unique @db.VarChar(255)
  password   String    @db.VarChar(255)
  dob        DateTime? @db.Date
  country    String?   @db.VarChar(100)
  isAdmin    Boolean   @default(false)
  isActive   Boolean   @default(true)

  // Vector lưu trữ User Factors từ ALS (Giả sử số chiều k = 64)
  alsFeature Unsupported("vector(64)")?

  // Quan hệ
  artist              Artist?
  playlists           Playlist[]
  follows             Follow[]              @relation("Follower")
  followedBy          Follow[]              @relation("Followee")
  interactions        Interaction[]
  recommendationCache RecommendationCache[]
}

model Artist {
  userId       Int     @id
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  artistBio    String? @db.Text
  verifiedTick Boolean @default(false)

  albums Album[]
  songs  ArtistSong[]
}

model Playlist {
  id          Int    @id @default(autoincrement())
  title       String @db.VarChar(255)
  playlistUrl String @unique @db.VarChar(255)
  userId      Int
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  songs PlaylistSong[]
}

model Album {
  id           Int       @id @default(autoincrement())
  type         String?   @db.VarChar(50)
  releasedDate DateTime? @db.Date
  artistId     Int
  artist       Artist    @relation(fields: [artistId], references: [userId], onDelete: Cascade)

  songs AlbumSong[]
}

model Song {
  id          Int     @id @default(autoincrement())
  title       String  @db.VarChar(255)
  energy      Float? // Đổi sang Float để Node.js/Python tính toán không cần parse
  tempo       Float? // Đổi sang Float
  status      String? @db.VarChar(50)

  // Vector lưu trữ Item Features (Cho CBF hoặc Item Factors của ALS)
  embedding Unsupported("vector(64)")?

  // Streaming URLs
  audioUrl    String  @db.VarChar(500)
  coverArtUrl String? @db.VarChar(500)
  durationMs  Int
  isDeleted   Boolean @default(false)

  // Quan hệ
  genres              SongGenre[]
  albums              AlbumSong[]
  interactions        Interaction[]
  playlists           PlaylistSong[]
  artists             ArtistSong[]
  charts              ChartSong[]
  recommendationCache RecommendationCache[]

  // Tối ưu câu lệnh WHERE isDeleted = false khi quét toàn bộ bảng
  @@index([isDeleted])
}

model Genre {
  id       Int    @id @default(autoincrement())
  genreTag String @unique @db.VarChar(100)

  songs SongGenre[]
}

model Chart {
  id        Int      @id @default(autoincrement())
  chartType String?  @db.VarChar(100)
  updateAt  DateTime @default(now())

  songs ChartSong[]
}

// ==========================================
// 2. CÁC BẢNG TRUNG GIAN & HỆ THỐNG GỢI Ý
// ==========================================

// Bảng lưu trữ kết quả chạy ngầm từ Python API
model RecommendationCache {
  id         Int      @id @default(autoincrement())
  userId     Int
  songId     Int
  finalScore Float // Điểm gợi ý đã được tổng hợp (ALS + Content Based)
  updatedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  // Tối ưu việc lấy Top N bài hát có điểm cao nhất cho 1 user
  @@index([userId, finalScore(sort: Desc)])
  
  // Đảm bảo không insert trùng 1 bài nhiều lần cho 1 user trong cache
  @@unique([userId, songId])
}

model Follow {
  followerId Int
  followeeId Int
  follower   User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followee   User @relation("Followee", fields: [followeeId], references: [id], onDelete: Cascade)

  @@id([followerId, followeeId])
}

model Interaction {
  userId         Int
  songId         Int
  timeStamp      DateTime @default(now())
  completionRate Float?   // Tính bằng: durationPlayed / tổng thời lượng bài hát
  isLiked        Boolean  @default(false)
  isSkipped      Boolean  @default(false) // Bổ sung cờ đánh dấu bấm Next
  durationPlayed Int?
  
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  song           Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  // Khóa chính đảm bảo lưu được mọi sự kiện nghe lại (Replay)
  @@id([userId, songId, timeStamp])

  @@index([userId, timeStamp])
}

model PlaylistSong {
  playlistId Int
  songId     Int
  addAt      DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  song     Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@id([playlistId, songId])
}

model ArtistSong {
  artistId Int
  songId   Int

  artist Artist @relation(fields: [artistId], references: [userId], onDelete: Cascade)
  song   Song   @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@id([artistId, songId])
}

model AlbumSong {
  albumId Int
  songId  Int

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)
  song  Song  @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@id([albumId, songId])
}

model SongGenre {
  songId  Int
  genreId Int

  song  Song  @relation(fields: [songId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([songId, genreId])
}

model ChartSong {
  chartId    Int
  songId     Int
  totalScore Float? // Đổi sang Float
  rank       Int?
  chart      Chart  @relation(fields: [chartId], references: [id], onDelete: Cascade)
  song       Song   @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@id([chartId, songId])
}
